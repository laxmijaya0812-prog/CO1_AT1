def T(n):
    if n == 1:
        return 1
    return 2 * T(n // 2) + (n * n)

n = int(input("Enter the value of n (power of 2): "))

print("\nAutonomous Vehicle Navigation System")
print("------------------------------------")
print("n\tT(n)")

values = [1, 2, 4, 8, 16, 32]

for i in values:
    if i <= n:
        print(i, "\t", T(i))

print("\nTime Complexity = Θ(n²)") 
