import math

def T(n):
    if n == 1:
        return 1
    return T(n - 1) + math.log2(n)

n = int(input("Enter the value of n: "))

print("\nDigital Library Search Engine")
print("-----------------------------")
print("n\tT(n)")

for i in range(1, n + 1):
    print(i, "\t", round(T(i), 2))

print("\nTime Complexity = Θ(n log n)")
